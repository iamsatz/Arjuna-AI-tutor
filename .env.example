# Phase: v0 (default) or alpha — unlock Talk/Photo only after V0 gate
NEXT_PUBLIC_ARJUNA_PHASE=v0

# Sarvam AI — free at https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Google AI Studio — required when NEXT_PUBLIC_ARJUNA_PHASE=alpha
# Free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Cloud API (optional until v1 parent summaries)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
PARENT_PHONE_MOTHER=
PARENT_PHONE_FATHER=

# Capacitor APK — WebView loads this URL (same Wi‑Fi IP or Vercel HTTPS)
CAPACITOR_SERVER_URL=http://192.168.0.20:3000

# TV testing: same APK on Android TV, or open http://YOUR_IP:3000/tv in TV browser
# Phone shows a 4-digit code → enter on TV to mirror session

# Owner dashboard at /owner — password-only login
OWNER_PASSWORD=your_owner_password_here
