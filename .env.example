# Phase: v0 (default) or alpha — alpha enables full lesson MVP
NEXT_PUBLIC_ARJUNA_PHASE=alpha

# Sarvam AI — free at https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Google AI Studio — required for alpha teaching
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (reuse existing project — run supabase/migrations/001_arjuna_mvp.sql first)
NEXT_PUBLIC_SUPABASE_URL=https://shikwtguxfhefzvfkedo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Optional: server-side writes if RLS blocks anon inserts
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API (optional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
PARENT_PHONE_MOTHER=
PARENT_PHONE_FATHER=

# Capacitor APK — WebView loads this URL (HTTPS for production testers)
CAPACITOR_SERVER_URL=https://your-app.vercel.app

# Owner dashboard at /owner
OWNER_PASSWORD=your_owner_password_here
